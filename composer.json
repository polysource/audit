{
    "name": "polysource/audit",
    "description": "Polysource — audit log for non-Doctrine actions: AuditEntry VO, fan-out logger interface, browsable AuditLogResource, GDPR Art. 30 CSV export, retention command.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "polysource",
        "audit",
        "audit-log",
        "compliance",
        "gdpr",
        "symfony"
    ],
    "homepage": "https://github.com/polysource/polysource",
    "support": {
        "issues": "https://github.com/polysource/polysource/issues",
        "source": "https://github.com/polysource/polysource"
    },
    "require": {
        "php": ">=8.1",
        "polysource/core": "0.1.x-dev",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "symfony/config": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/event-dispatcher": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/http-foundation": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/uid": "^5.4 || ^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "doctrine/dbal": "^3.6 || ^4.0",
        "doctrine/orm": "^2.20 || ^3.0",
        "phpunit/phpunit": "^10.5 || ^11.5",
        "polysource/symfony-bundle": "0.1.x-dev",
        "symfony/security-bundle": "^5.4 || ^6.0 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Polysource\\Audit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Polysource\\Audit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
